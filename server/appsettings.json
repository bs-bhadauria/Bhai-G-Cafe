{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://127.0.0.1:5500",
      "http://localhost:5500"
    ]
  },
  "Storage": {
    "DataDirectory": "App_Data",
    "OrdersFile": "orders.json"
  },
  "Database": {
    "Provider": "postgres",
    "AutoMigrateOnStartup": true,
    "ImportLegacyJsonOnStartup": false
  },
  "Admin": {
    "ApiKey": "change-this-admin-key"
  },
  "Payments": {
    "Provider": "Razorpay",
    "Currency": "INR",
    "Razorpay": {
      "KeyId": "",
      "KeySecret": "",
      "WebhookSecret": ""
    }
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "ProviderUrl": "",
      "ApiKey": "",
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer",
      "FromAddress": "orders@bhaigcafe.example"
    },
    "Sms": {
      "Enabled": false,
      "ProviderUrl": "",
      "ApiKey": "",
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer",
      "SenderId": "BHAIGC"
    }
  }
}
