      "Enabled": false,
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer"
    },
    "Sms": {
      "Enabled": false,
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer"
    }
  }
