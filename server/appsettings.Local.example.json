{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=bhaigcafe;Username=postgres;Password=replace-with-strong-password;SSL Mode=Prefer;Trust Server Certificate=true"
  },
  "Database": {
    "Provider": "postgres",
    "AutoMigrateOnStartup": true,
    "ImportLegacyJsonOnStartup": true
  },
  "Admin": {
    "ApiKey": "replace-with-a-long-random-admin-key"
  },
  "Payments": {
    "Provider": "Razorpay",
    "Currency": "INR",
    "Razorpay": {
      "KeyId": "rzp_test_xxxxxxxxxxxxx",
      "KeySecret": "replace-with-razorpay-secret",
      "WebhookSecret": "replace-with-webhook-secret"
    }
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "ProviderUrl": "https://your-email-provider.example/api/send",
      "ApiKey": "replace-with-email-provider-api-key",
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer",
      "FromAddress": "orders@bhaigcafe.example"
    },
    "Sms": {
      "Enabled": false,
      "ProviderUrl": "https://your-sms-provider.example/api/send",
      "ApiKey": "replace-with-sms-provider-api-key",
      "AuthHeaderName": "Authorization",
      "AuthScheme": "Bearer",
      "SenderId": "BHAIGC"
    }
  }
}
